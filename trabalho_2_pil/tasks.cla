#include "driverlib.h"
#include "board.h"
#include "shared_vars.h"



#define B0 0.001033f
#define B1 0.000767f
#define B2 -0.000266f
#define A1 -1.521886f
#define A2 0.521886f

//#define REF 20.0F
#define UL 1.0f
#define LL 0.0f

__interrupt void Cla1Task1()
{
    x[2] = x[1]; x[1] = x[0]; x[0] = REF - vo;
    y[2] = y[1]; y[1] = y[0];
    y[0] = B0*x[0] + B1*x[1] + B2*x[2] - A1*y[1] - A2*y[2];

    y[0] = (y[0] > UL) ? UL : y[0];
    y[0] = (y[0] < LL) ? LL : y[0];
}
